<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Production config:
        - HTTPS only for public traffic
        - Trust system certs + user-installed certs (self-signed gateway support)
        - Allow HTTP only on RFC-1918 private networks (LAN deployment)
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- 192.168.0.0/16 — home/office LAN -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.0.1</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.31.1</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- 10.0.0.0/8 — corporate / VPN / Docker -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.0.1</domain>
        <domain includeSubdomains="false">10.8.0.1</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

    <!-- localhost / loopback -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>

</network-security-config>
